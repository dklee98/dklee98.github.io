---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Experience" description="Research experience of Dongkyu Lee">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">Research Experience</h1>

  <div class="space-y-8">

    <!-- URobotics -->
    <div class="flex gap-6 items-start">
      <div class="w-32 flex-shrink-0 mt-1">
        <img src="/images/urobotics.png" alt="URobotics Corp." class="w-full object-contain"
          onerror="this.onerror=null;this.src='';this.alt='URobotics';" />
      </div>
      <div>
        <p class="text-base font-semibold text-gray-900 dark:text-gray-100">CTO and Co-Founder</p>
        <p class="text-sm text-gray-700 dark:text-gray-300 mt-0.5">
          <a href="https://urobotics.ai" class="text-blue-700 dark:text-blue-400 hover:underline" target="_blank">URobotics Corp.</a>, South Korea
        </p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Apr. 2025 – Present</p>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">
          Building autonomous navigation software for legged robots. Co-founded the company with a vision to enable robots to move autonomously in every environment.
        </p>
      </div>
    </div>

    <div class="border-t border-gray-100 dark:border-gray-700"></div>

    <!-- Urban Robotics Lab KAIST -->
    <div class="flex gap-6 items-start">
      <div class="w-32 flex-shrink-0 mt-1">
        <img src="/images/kaist.png" alt="KAIST" class="w-full object-contain"
          onerror="this.onerror=null;this.src='';this.alt='KAIST';" />
      </div>
      <div>
        <p class="text-base font-semibold text-gray-900 dark:text-gray-100">Ph.D. Candidate (Current) / M.S. Researcher</p>
        <p class="text-sm text-gray-700 dark:text-gray-300 mt-0.5">
          <a href="https://urobot.kaist.ac.kr" class="text-blue-700 dark:text-blue-400 hover:underline" target="_blank">Urban Robotics Lab</a>,
          <a href="https://kaist.ac.kr/" class="text-blue-700 dark:text-blue-400 hover:underline" target="_blank">KAIST</a>, South Korea
        </p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Sep. 2021 – Present</p>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-2">
          Research on autonomous navigation for legged robots, focusing on traversal risk estimation, path planning, and long-term field deployments. Advised by Prof. Hyun Myung.
        </p>
      </div>
    </div>

    <div class="border-t border-gray-100 dark:border-gray-700"></div>

    <!-- Research Intern KAIST (before M.S.) -->
    <div class="flex gap-6 items-start">
      <div class="w-32 flex-shrink-0 mt-1">
        <img src="/images/kaist.png" alt="KAIST" class="w-full object-contain"
          onerror="this.onerror=null;this.src='';this.alt='KAIST';" />
      </div>
      <div>
        <p class="text-base font-semibold text-gray-900 dark:text-gray-100">Research Intern</p>
        <p class="text-sm text-gray-700 dark:text-gray-300 mt-0.5">Urban Robotics Lab, KAIST, South Korea</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Feb. 2021 – Aug. 2021</p>
      </div>
    </div>

    <div class="border-t border-gray-100 dark:border-gray-700"></div>

    <!-- ETRI -->
    <div class="flex gap-6 items-start">
      <div class="w-32 flex-shrink-0 mt-1">
        <img src="/images/etri.png" alt="ETRI" class="w-full object-contain"
          onerror="this.onerror=null;this.src='';this.alt='ETRI';" />
      </div>
      <div>
        <p class="text-base font-semibold text-gray-900 dark:text-gray-100">Research Intern</p>
        <p class="text-sm text-gray-700 dark:text-gray-300 mt-0.5">Artificial Intelligence Research Team, Electronics and Telecommunications Research Institute (ETRI), South Korea</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Jan. 2021 – Feb. 2021</p>
      </div>
    </div>

    <div class="border-t border-gray-100 dark:border-gray-700"></div>

    <!-- Software Maestro -->
    <div class="flex gap-6 items-start">
      <div class="w-32 flex-shrink-0 mt-1">
        <img src="/images/swm.png" alt="Software Maestro" class="w-full object-contain"
          onerror="this.onerror=null;this.src='';this.alt='SWM';" />
      </div>
      <div>
        <p class="text-base font-semibold text-gray-900 dark:text-gray-100">Research Intern</p>
        <p class="text-sm text-gray-700 dark:text-gray-300 mt-0.5">Software Maestro 11th, Ministry of Science and ICT (MSIT), South Korea</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Jun. 2020 – Dec. 2020</p>
      </div>
    </div>

  </div>
</Layout>
