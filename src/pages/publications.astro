---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Publications" description="Publications by Dongkyu Lee - robotics researcher at KAIST">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Publications</h1>
  <p class="text-sm text-gray-500 mb-8">
    Also see: <a href="https://scholar.google.com/citations?user=84Gdj_oAAAAJ&hl=ko&oi=sra" class="text-blue-700 hover:underline" target="_blank">Google Scholar</a>
  </p>

  <!-- Journal Papers -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-800 mb-4 border-b border-gray-200 pb-2">Journal Papers</h2>
    <ol class="space-y-6 list-none">
      <li class="flex gap-4 items-start">
        <img src="/images/trg.png" alt="TRG-Planner" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
          onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            TRG-Planner: Traversal Risk Graph-Based Path Planning in Unstructured Environments for Safe and Efficient Navigation
          </p>
          <p class="text-xs text-gray-600 mt-1">
            <strong>Dongkyu Lee</strong>, I Made Aswin Nahrendra, Minho Oh, Byeongho Yu, and Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            IEEE Robotics and Automation Letters <strong>(RA-L)</strong>, 2025 · IEEE/RSJ International Conference on Intelligent Robots and Systems <strong>(IROS)</strong>, 2025 [Oral]
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://arxiv.org/abs/2501.01806" class="text-xs text-blue-700 hover:underline" target="_blank">[Paper]</a>
            <a href="https://trg-planner.github.io/" class="text-xs text-blue-700 hover:underline" target="_blank">[Project]</a>
          </div>
        </div>
      </li>
    </ol>
  </section>

  <!-- Conference Papers -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-800 mb-4 border-b border-gray-200 pb-2">Conference Papers</h2>
    <ol class="space-y-6 list-none">

      <li class="flex gap-4 items-start">
        <img src="/images/dreamflex.png" alt="DreamFLEX" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
          onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            DreamFLEX: Learning Fault-Aware Quadrupedal Locomotion Controller for Anomaly Situation in Rough Terrains
          </p>
          <p class="text-xs text-gray-600 mt-1">
            Seunghyun Lee, I Made Aswin Nahrendra, <strong>Dongkyu Lee</strong>, Byeongho Yu, Minho Oh, and Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            IEEE International Conference on Robotics and Automation <strong>(ICRA)</strong>, 2025
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://dreamflex.github.io" class="text-xs text-blue-700 hover:underline" target="_blank">[Project]</a>
          </div>
        </div>
      </li>

      <li class="flex gap-4 items-start">
        <div class="w-36 h-24 rounded border border-gray-200 flex-shrink-0 bg-gray-50 flex items-center justify-center text-xs text-gray-400">No image</div>
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            B-TMS: Bayesian Traversable Terrain Modeling and Segmentation Across 3D LiDAR Scans and Maps for Enhanced Off-Road Navigation
          </p>
          <p class="text-xs text-gray-600 mt-1">
            Minho Oh, Gunhee Shin, Seoyeon Jang, Seungjae Lee, <strong>Dongkyu Lee</strong>, Wonho Song, Byeongho Yu, Hyungtae Lim, Jaeyoung Lee, Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            IEEE Intelligent Vehicles Symposium <strong>(IV)</strong>, 2024
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://ieeexplore.ieee.org/abstract/document/10588810" class="text-xs text-blue-700 hover:underline" target="_blank">[Paper]</a>
          </div>
        </div>
      </li>

      <li class="flex gap-4 items-start">
        <div class="w-36 h-24 rounded border border-gray-200 flex-shrink-0 bg-gray-50 flex items-center justify-center text-xs text-gray-400">No image</div>
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            M-BRIC: design of mass-driven bi-rotor with RL-based intelligent controller
          </p>
          <p class="text-xs text-gray-600 mt-1">
            <strong>Dongkyu Lee</strong>, EungChang Mason Lee, Duckyu Choi, Junho Choi, Christian Tirtawardhana, Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            International Conference on Ubiquitous Robots <strong>(UR)</strong>, 2022
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://ieeexplore.ieee.org/abstract/document/9826246" class="text-xs text-blue-700 hover:underline" target="_blank">[Paper]</a>
          </div>
        </div>
      </li>

      <li class="flex gap-4 items-start">
        <div class="w-36 h-24 rounded border border-gray-200 flex-shrink-0 bg-gray-50 flex items-center justify-center text-xs text-gray-400">No image</div>
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            FARO-Tracker: Fast and robust target tracking system for UAVs in urban environment
          </p>
          <p class="text-xs text-gray-600 mt-1">
            <strong>Dongkyu Lee</strong>, EungChang Mason Lee, Hyungtae Lim, Seungwon Song, Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            International Conference on Robot Intelligence Technology and Applications <strong>(RiTA)</strong>, 2022
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://link.springer.com/chapter/10.1007/978-3-031-26889-2_20" class="text-xs text-blue-700 hover:underline" target="_blank">[Paper]</a>
          </div>
        </div>
      </li>

      <li class="flex gap-4 items-start">
        <div class="w-36 h-24 rounded border border-gray-200 flex-shrink-0 bg-gray-50 flex items-center justify-center text-xs text-gray-400">No image</div>
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            CEO-MLCPP: Control-efficient and obstacle-aware multi-layer coverage path planner for 3D reconstruction with UAVs
          </p>
          <p class="text-xs text-gray-600 mt-1">
            Eungchang Mason Lee, Sungwook Jung, Seungwon Song, Duckyu Choi, <strong>Dongkyu Lee</strong>, Seunghyun Lee, Seoktae Kim, Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            International Conference on Robot Intelligence Technology and Applications <strong>(RiTA)</strong>, 2022
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://link.springer.com/chapter/10.1007/978-3-031-26889-2_3" class="text-xs text-blue-700 hover:underline" target="_blank">[Paper]</a>
          </div>
        </div>
      </li>
    </ol>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-800 mb-4 border-b border-gray-200 pb-2">Recent Papers</h2>
    <ol class="space-y-6 list-none">
      <li class="flex gap-4 items-start">
        <img src="/images/dreamwaqpp.png" alt="DreamWaQ++" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
          onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            DreamWaQ++: Obstacle-aware Quadrupedal Locomotion with Resilient Multi-modal Reinforcement Learning
          </p>
          <p class="text-xs text-gray-600 mt-1">
            I Made Aswin Nahrendra, Byeongho Yu, Minho Oh, <strong>Dongkyu Lee</strong>, Seunghyun Lee, Hyeonwoo Lee, Hyungtae Lim, and Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            IEEE Transactions on Robotics <strong>(T-RO)</strong>, 2025
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://arxiv.org/pdf/2409.19709" class="text-xs text-blue-700 hover:underline" target="_blank">[Paper]</a>
            <a href="https://dreamwaqpp.github.io" class="text-xs text-blue-700 hover:underline" target="_blank">[Project]</a>
          </div>
        </div>
      </li>

      <li class="flex gap-4 items-start">
        <img src="/images/dreamflow.png" alt="DreamFlow" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
          onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            DreamFlow: Local Navigation Beyond Observation via Conditional Flow Matching in the Latent Space
          </p>
          <p class="text-xs text-gray-600 mt-1">
            Jiwon Park, <strong>Dongkyu Lee</strong>, I Made Aswin Nahrendra, Jaeyoung Lim, and Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            IEEE International Conference on Robotics and Automation <strong>(ICRA)</strong>, 2026
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://dreamflow-icra.github.io" class="text-xs text-blue-700 hover:underline" target="_blank">[Project]</a>
          </div>
        </div>
      </li>

      <li class="flex gap-4 items-start">
        <img src="/images/humanoids.png" alt="Humanoids Workshop" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
          onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            Learning Resilent Blind Locomotion Controller for Humanoid Robots using Deep Reinforcement Learning
          </p>
          <p class="text-xs text-gray-600 mt-1">
            Seunghyun Lee, <strong>Dongkyu Lee</strong>, Byeongho Yu, I Made Aswin Nahrendra, and Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5">
            IEEE Humanoids Workshop <strong>(2025)</strong>
          </p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://drive.google.com/file/d/1geRp5MYSBh2MD_HzsotdCSv8JW7yzz3O/view" class="text-xs text-blue-700 hover:underline" target="_blank">[Paper]</a>
          </div>
        </div>
      </li>

      <li class="flex gap-4 items-start">
        <img src="/images/trip.png" alt="TRIP" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
          onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">
            TRIP: Terrain Traversability Mapping With Risk-Aware Prediction for Enhanced Online Quadrupedal Robot Navigation
          </p>
          <p class="text-xs text-gray-600 mt-1">
            Minho Oh, Byeongho Yu, I Made Aswin Nahrendra, Seoyeon Jang, Hyeonwoo Lee, <strong>Dongkyu Lee</strong>, Seungjae Lee, Yeeun Kim, Marsim Kevin Christiansen, Hyungtae Lim, Hyun Myung
          </p>
          <p class="text-xs text-gray-500 mt-0.5 italic">under review</p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://arxiv.org/abs/2411.17134" class="text-xs text-blue-700 hover:underline" target="_blank">[Paper]</a>
          </div>
        </div>
      </li>
    </ol>
