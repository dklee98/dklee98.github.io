<script>
  function toggleNews() {
    const extras = document.querySelectorAll('.news-extra');
    const btn = document.getElementById('news-toggle');
    const isHidden = extras[0].classList.contains('hidden');
    extras.forEach(el => el.classList.toggle('hidden'));
    btn!.textContent = isHidden ? '− Less' : '+ More news';
  }
  (window as any).toggleNews = toggleNews;
</script>
