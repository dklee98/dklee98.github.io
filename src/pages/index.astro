---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">

  <!-- Hero / About Section -->
  <section id="about" class="flex flex-col md:flex-row gap-8 items-start mb-12">
    <div class="flex-shrink-0">
      <img
        src="/images/dongkyu_profile_zoomzoom.png"
        alt="Dongkyu Lee"
        class="w-40 h-40 rounded-2xl object-cover border-2 border-gray-200 shadow"
        onerror="this.onerror=null;this.src='https://via.placeholder.com/160x160?text=DL';"
      />
    </div>
    <div class="flex-1">
      <h1 class="text-3xl font-bold text-gray-900 mb-1">Dongkyu Lee</h1>
      <p class="text-base text-blue-700 font-medium mb-3">
        CTO &amp; Co-Founder at URobotics Corp.
      </p>
      <p class="text-sm text-gray-600 mb-4">dklee [at] urobotics [dot] ai</p>
      <div class="flex gap-3 flex-wrap mb-4">
        <a href="https://github.com/dklee98" target="_blank" rel="noopener" class="text-sm text-gray-600 hover:text-blue-700 flex items-center gap-1">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/dongkyu-danial-lee" target="_blank" rel="noopener" class="text-sm text-gray-600 hover:text-blue-700 flex items-center gap-1">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href="https://scholar.google.com/citations?user=84Gdj_oAAAAJ&hl=ko&oi=sra" target="_blank" rel="noopener" class="text-sm text-gray-600 hover:text-blue-700 flex items-center gap-1">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/></svg>
          Google Scholar
        </a>
        <a href="https://urobotics.ai" target="_blank" rel="noopener" class="text-sm text-gray-600 hover:text-blue-700">🤖 URobotics</a>
      </div>
      <div class="prose prose-sm max-w-none text-gray-700 leading-relaxed mb-6">
        <p>
          I am CTO and Co-Founder at <a href="https://urobotics.ai" class="text-blue-700 hover:underline">URobotics Corp.</a>,
          a startup developing autonomous navigation software for legged robots.
          I am also a Ph.D. candidate in the <a href="https://ee.kaist.ac.kr/" class="text-blue-700 hover:underline">Department of Electrical Engineering</a> at
          <a href="https://kaist.ac.kr/" class="text-blue-700 hover:underline">KAIST</a>,
          member of the <a href="https://urobot.kaist.ac.kr" class="text-blue-700 hover:underline">Urban Robotics Lab</a> led by Prof.
          <a href="https://urobot.kaist.ac.kr/url_teams/prof-hyunmyung/" class="text-blue-700 hover:underline">Hyun Myung</a>.
          My research focuses on <strong>autonomous navigation for legged robots</strong> — path planning, decision-making, and long-term field robotics.
        </p>
      </div>

      <!-- Education Card -->
      <div class="border border-gray-200 rounded-xl overflow-hidden">
        <div class="bg-gray-50 px-4 py-2 border-b border-gray-200">
          <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide">Education</p>
        </div>
        <div class="divide-y divide-gray-100">
          <div class="grid grid-cols-[3.5rem_minmax(0,1.4fr)_minmax(0,1fr)_6.5rem] gap-x-4 items-center px-4 py-3 text-sm">
            <span class="font-semibold text-gray-800">Ph.D.</span>
            <span class="text-gray-600">Electrical Engineering</span>
            <span class="text-gray-600">KAIST</span>
            <span class="text-gray-400 text-xs whitespace-nowrap text-right">2023 – Present</span>
          </div>
          <div class="grid grid-cols-[3.5rem_minmax(0,1.4fr)_minmax(0,1fr)_6.5rem] gap-x-4 items-center px-4 py-3 text-sm">
            <span class="font-semibold text-gray-800">M.S.</span>
            <span class="text-gray-600">Robotics Program</span>
            <span class="text-gray-600">KAIST</span>
            <span class="text-gray-400 text-xs whitespace-nowrap text-right">2021 – 2023</span>
          </div>
          <div class="grid grid-cols-[3.5rem_minmax(0,1.4fr)_minmax(0,1fr)_6.5rem] gap-x-4 items-center px-4 py-3 text-sm">
            <span class="font-semibold text-gray-800">B.S.</span>
            <span class="text-gray-600">Electrical &amp; Computer Eng.</span>
            <span class="text-gray-600">UOS</span>
            <span class="text-gray-400 text-xs whitespace-nowrap text-right">2016 – 2021</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- News -->
  <section id="news" class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-4 border-b border-gray-200 pb-2">News</h2>
    <ul class="space-y-3 text-sm text-gray-700">
      <li class="flex gap-3">
        <span class="text-gray-400 flex-shrink-0 w-24">Feb. 2026</span>
        <span><em>DreamFlow</em> accepted to <strong>ICRA 2026</strong>. <a href="https://dreamflow-icra.github.io" class="text-blue-700 hover:underline">[Project]</a></span>
      </li>
      <li class="flex gap-3">
        <span class="text-gray-400 flex-shrink-0 w-24">Dec. 2025</span>
        <span><em>DreamWaQ++</em> accepted to <strong>IEEE T-RO 2025</strong>. <a href="https://arxiv.org/pdf/2409.19709" class="text-blue-700 hover:underline">[Paper]</a> <a href="https://dreamwaqpp.github.io" class="text-blue-700 hover:underline">[Project]</a></span>
      </li>
      <li class="flex gap-3">
        <span class="text-gray-400 flex-shrink-0 w-24">Oct. 2025</span>
        <span>Presented a paper on humanoid locomotion at <strong>IEEE Humanoids Workshop 2025</strong>. <a href="https://drive.google.com/file/d/1geRp5MYSBh2MD_HzsotdCSv8JW7yzz3O/view" class="text-blue-700 hover:underline">[Paper]</a></span>
      </li>
      <li class="flex gap-3">
        <span class="text-gray-400 flex-shrink-0 w-24">Jul. 2025</span>
        <span><em>TRG-planner</em> presented as an <strong>IROS 2025 Oral</strong>. <a href="https://trg-planner.github.io/" class="text-blue-700 hover:underline">[Project]</a></span>
      </li>
      <li class="flex gap-3">
        <span class="text-gray-400 flex-shrink-0 w-24">Apr. 2025</span>
        <span>Co-founded <a href="https://urobotics.ai" class="text-blue-700 hover:underline">URobotics Corp.</a> as CTO.</span>
      </li>
      <li class="flex gap-3 news-extra hidden">
        <span class="text-gray-400 flex-shrink-0 w-24">Jan. 2025</span>
        <span><em>DreamFLEX</em> accepted to <strong>ICRA 2025</strong>. <a href="https://dreamflex.github.io" class="text-blue-700 hover:underline">[Project]</a></span>
      </li>
      <li class="flex gap-3 news-extra hidden">
        <span class="text-gray-400 flex-shrink-0 w-24">Dec. 2024</span>
        <span><em>TRG-planner</em> accepted to <strong>IEEE RA-L 2025</strong>. <a href="https://arxiv.org/abs/2501.01806" class="text-blue-700 hover:underline">[Paper]</a> <a href="https://trg-planner.github.io/" class="text-blue-700 hover:underline">[Project]</a></span>
      </li>
      <li class="flex gap-3 news-extra hidden">
        <span class="text-gray-400 flex-shrink-0 w-24">May. 2024</span>
        <span>Team DreamTRIP — <strong>2nd Place</strong>, Autonomous Quadrupedal Robot Challenge, ICRA 2024, Yokohama.</span>
      </li>
      <li class="flex gap-3 news-extra hidden">
        <span class="text-gray-400 flex-shrink-0 w-24">Feb. 2024</span>
        <span><strong>Best Work Award</strong> at KROC 2024 RED Show.</span>
      </li>
      <li class="flex gap-3 news-extra hidden">
        <span class="text-gray-400 flex-shrink-0 w-24">May. 2023</span>
        <span>Team DreamSTEP — <strong>1st Place</strong>, Autonomous Quadrupedal Robot Challenge, ICRA 2023, London.</span>
      </li>
    </ul>
    <button id="news-toggle" onclick="toggleNews()" class="mt-3 text-xs text-blue-700 hover:underline">+ More news</button>
  </section>

  <!-- Research Experience -->
  <section id="experience" class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-4 border-b border-gray-200 pb-2">Research Experience</h2>
    <div class="space-y-6">
      <div class="flex gap-5 items-start">
        <img src="/images/urobotics.png" alt="URobotics" class="w-24 h-16 object-contain flex-shrink-0" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-bold text-gray-900">CTO and Co-Founder</p>
          <p class="text-sm text-gray-600"><a href="https://urobotics.ai" class="text-blue-700 hover:underline">URobotics Corp.</a>, South Korea</p>
          <p class="text-sm text-gray-500">Mobility Intelligence Team &amp; Robot System Team</p>
          <p class="text-xs text-gray-400">Apr. 2025 – Present</p>
        </div>
      </div>
      <div class="flex gap-5 items-start">
        <img src="/images/kaist.png" alt="KAIST" class="w-24 h-16 object-contain flex-shrink-0" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-bold text-gray-900">Research Intern</p>
          <p class="text-sm text-gray-600"><a href="https://kaist.ac.kr/" class="text-blue-700 hover:underline">KAIST</a>, South Korea</p>
          <p class="text-sm text-gray-500"><a href="https://urobot.kaist.ac.kr" class="text-blue-700 hover:underline">Urban Robotics Lab</a></p>
          <p class="text-xs text-gray-400">Mar. 2021 – Aug. 2021</p>
        </div>
      </div>
      <div class="flex gap-5 items-start">
        <img src="/images/etri.png" alt="ETRI" class="w-24 h-16 object-contain flex-shrink-0" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-bold text-gray-900">Research Intern</p>
          <p class="text-sm text-gray-600">ETRI, South Korea</p>
          <p class="text-sm text-gray-500">AI Research Team</p>
          <p class="text-xs text-gray-400">Jan. 2021 – Feb. 2021</p>
        </div>
      </div>
      <div class="flex gap-5 items-start">
        <img src="/images/swm.png" alt="Software Maestro" class="w-24 h-16 object-contain flex-shrink-0" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-bold text-gray-900">Research Intern</p>
          <p class="text-sm text-gray-600">MSIT, South Korea</p>
          <p class="text-sm text-gray-500">Software Maestro 11th</p>
          <p class="text-xs text-gray-400">Jun. 2020 – Dec. 2020</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Highlights -->
  <section id="highlights" class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-4 border-b border-gray-200 pb-2">Research Highlights</h2>
    <div class="space-y-6">
      <div class="flex gap-4 items-start">
        <img src="/images/trg.png" alt="TRG-Planner" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">TRG-planner: Traversal Risk Graph-Based Path Planning in Unstructured Environments for Safe and Efficient Navigation</p>
          <p class="text-xs text-gray-600 mt-1"><strong>Dongkyu Lee</strong>, I Made Aswin Nahrendra, Minho Oh, Byeongho Yu, and Hyun Myung</p>
          <p class="text-xs mt-1"><span class="inline-block bg-blue-100 text-blue-700 rounded px-2 py-0.5 font-medium">IEEE RA-L 2025 · IROS 2025 Oral</span></p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://arxiv.org/abs/2501.01806" class="text-xs text-blue-700 hover:underline">[Paper]</a>
            <a href="https://trg-planner.github.io/" class="text-xs text-blue-700 hover:underline">[Project]</a>
          </div>
        </div>
      </div>
      <div class="flex gap-4 items-start">
        <img src="/images/dreamflex.png" alt="DreamFLEX" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">DreamFLEX: Learning Fault-Aware Quadrupedal Locomotion Controller for Anomaly Situation in Rough Terrains</p>
          <p class="text-xs text-gray-600 mt-1">Seunghyun Lee, I Made Aswin Nahrendra, <strong>Dongkyu Lee</strong>, Byeongho Yu, Minho Oh, and Hyun Myung</p>
          <p class="text-xs mt-1"><span class="inline-block bg-blue-100 text-blue-700 rounded px-2 py-0.5 font-medium">IEEE ICRA 2025</span></p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://dreamflex.github.io" class="text-xs text-blue-700 hover:underline">[Project]</a>
          </div>
        </div>
      </div>
      <div class="flex gap-4 items-start">
        <img src="/images/dreamwaqpp.png" alt="DreamWaQ++" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">DreamWaQ++: Obstacle-aware Quadrupedal Locomotion with Resilient Multi-modal Reinforcement Learning</p>
          <p class="text-xs text-gray-600 mt-1">I Made Aswin Nahrendra, Byeongho Yu, Minho Oh, <strong>Dongkyu Lee</strong>, Seunghyun Lee, Hyeonwoo Lee, Hyungtae Lim, and Hyun Myung</p>
          <p class="text-xs mt-1"><span class="inline-block bg-blue-100 text-blue-700 rounded px-2 py-0.5 font-medium">IEEE T-RO 2025</span></p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://arxiv.org/pdf/2409.19709" class="text-xs text-blue-700 hover:underline">[Paper]</a>
            <a href="https://dreamwaqpp.github.io" class="text-xs text-blue-700 hover:underline">[Project]</a>
          </div>
        </div>
      </div>
      <div class="flex gap-4 items-start">
        <img src="/images/dreamflow.png" alt="DreamFlow" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">DreamFlow: Local Navigation Beyond Observation via Conditional Flow Matching in the Latent Space</p>
          <p class="text-xs text-gray-600 mt-1">Jiwon Park, <strong>Dongkyu Lee</strong>, I Made Aswin Nahrendra, Jaeyoung Lim, and Hyun Myung</p>
          <p class="text-xs mt-1"><span class="inline-block bg-blue-100 text-blue-700 rounded px-2 py-0.5 font-medium">IEEE ICRA 2026</span></p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://dreamflow-icra.github.io" class="text-xs text-blue-700 hover:underline">[Project]</a>
          </div>
        </div>
      </div>
      <div class="flex gap-4 items-start">
        <img src="/images/humanoids.png" alt="Humanoids Workshop" class="w-36 h-24 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">Learning Resilent Blind Locomotion Controller for Humanoid Robots using Deep Reinforcement Learning</p>
          <p class="text-xs text-gray-600 mt-1">Seunghyun Lee, <strong>Dongkyu Lee</strong>, Byeongho Yu, I Made Aswin Nahrendra, and Hyun Myung</p>
          <p class="text-xs mt-1"><span class="inline-block bg-blue-100 text-blue-700 rounded px-2 py-0.5 font-medium">IEEE Humanoids Workshop 2025</span></p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://drive.google.com/file/d/1geRp5MYSBh2MD_HzsotdCSv8JW7yzz3O/view" class="text-xs text-blue-700 hover:underline">[Paper]</a>
          </div>
        </div>
      </div>
      <div class="flex gap-4 items-start">
        <div class="w-36 h-24 rounded border border-gray-200 flex-shrink-0 bg-gray-50 flex items-center justify-center text-xs text-gray-400 font-medium">LocoVLM</div>
        <div>
          <p class="text-sm font-semibold text-gray-900 leading-snug">Versatile Legged Locomotion Adaptation through Vision-Language Grounding</p>
          <p class="text-xs text-gray-600 mt-1">I Made Aswin Nahrendra, Seunghyun Lee, <strong>Dongkyu Lee</strong>, and Hyun Myung</p>
          <p class="text-xs mt-1"><span class="inline-block bg-blue-100 text-blue-700 rounded px-2 py-0.5 font-medium">SafeVLMs Workshop @ ICRA 2025</span></p>
          <div class="flex gap-3 mt-1.5">
            <a href="https://locovlm.github.io" class="text-xs text-blue-700 hover:underline">[Project]</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Publications Preview -->
  <section id="publications" class="mb-12">
    <div class="mb-4 border-b border-gray-200 pb-2">
      <h2 class="text-xl font-bold text-gray-900">Selected Publications</h2>
    </div>
    <p class="text-xs text-gray-500 mb-5">A short list here. Full publication history lives on the dedicated publications page.</p>

    <div class="space-y-4">
      <div>
        <p class="text-sm font-medium text-gray-900 leading-snug">TRG-planner: Traversal Risk Graph-Based Path Planning in Unstructured Environments for Safe and Efficient Navigation</p>
        <p class="text-xs text-gray-600 mt-0.5"><strong>Dongkyu Lee</strong>, I Made Aswin Nahrendra, Minho Oh, Byeongho Yu, Hyun Myung</p>
        <p class="text-xs text-gray-500">IEEE RA-L 2025 · IROS 2025 Oral · <a href="https://arxiv.org/abs/2501.01806" class="text-blue-700 hover:underline">[Paper]</a> <a href="https://trg-planner.github.io/" class="text-blue-700 hover:underline">[Project]</a></p>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-900 leading-snug">DreamWaQ++: Obstacle-aware Quadrupedal Locomotion with Resilient Multi-modal Reinforcement Learning</p>
        <p class="text-xs text-gray-600 mt-0.5">I Made Aswin Nahrendra, Byeongho Yu, Minho Oh, <strong>Dongkyu Lee</strong>, et al.</p>
        <p class="text-xs text-gray-500">IEEE T-RO 2025 · <a href="https://arxiv.org/pdf/2409.19709" class="text-blue-700 hover:underline">[Paper]</a> <a href="https://dreamwaqpp.github.io" class="text-blue-700 hover:underline">[Project]</a></p>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-900 leading-snug">DreamFlow: Local Navigation Beyond Observation via Conditional Flow Matching in the Latent Space</p>
        <p class="text-xs text-gray-600 mt-0.5">Jiwon Park, <strong>Dongkyu Lee</strong>, I Made Aswin Nahrendra, Jaeyoung Lim, Hyun Myung</p>
        <p class="text-xs text-gray-500">ICRA 2026 · <a href="https://dreamflow-icra.github.io" class="text-blue-700 hover:underline">[Project]</a></p>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section id="awards" class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-4 border-b border-gray-200 pb-2">Awards &amp; Honors</h2>
    <div class="space-y-5">
      <div class="flex gap-4 items-start">
        <img src="/images/dreamstep.jpg" alt="ICRA 2023" class="w-28 h-20 object-cover rounded border border-gray-200 flex-shrink-0" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900">Autonomous Quadrupedal Robot Challenge, ICRA 2023, London</p>
          <p class="text-sm font-bold text-blue-700">🥇 Winner (1st Place)</p>
          <p class="text-xs text-gray-500">Team DreamSTEP of KAIST · <a href="https://quadruped-robot-challenges.notion.site/ICRA-2023-Quadruped-Robot-Challenges-0d1513db048e40e1bbe6dd4ba5b78cdc" class="text-blue-700 hover:underline">[Link]</a></p>
        </div>
      </div>
      <div class="flex gap-4 items-start">
        <img src="/images/dreamtrip.png" alt="ICRA 2024" class="w-28 h-20 object-cover rounded border border-gray-200 flex-shrink-0" onerror="this.onerror=null;this.style.display='none';" />
        <div>
          <p class="text-sm font-semibold text-gray-900">Autonomous Quadrupedal Robot Challenge, ICRA 2024, Yokohama</p>
          <p class="text-sm font-bold text-gray-700">🥈 2nd Place</p>
          <p class="text-xs text-gray-500">Team DreamTRIP of KAIST · <a href="https://quadruped-robot-challenges.notion.site/ICRA-2024-Quadruped-Robot-Challenges-d208b535269d4a79b2893a84c1d4b2df" class="text-blue-700 hover:underline">[Link]</a></p>
        </div>
      </div>
      <div class="flex gap-4 items-start">
