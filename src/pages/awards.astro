---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Awards" description="Awards and honors of Dongkyu Lee">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Awards &amp; Honors</h1>

  <div class="space-y-8">

    <!-- ICRA 2023 -->
    <div class="flex gap-6 items-start">
      <img src="/images/dreamstep.jpg" alt="ICRA 2023 Challenge" class="w-36 h-28 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
        onerror="this.onerror=null;this.style.display='none';" />
      <div>
        <p class="text-sm font-semibold text-gray-900 leading-snug">
          Autonomous Quadrupedal Robot Challenge at ICRA 2023, London, UK
        </p>
        <p class="text-sm font-bold text-blue-700 mt-1">🥇 Winner (1st Place)</p>
        <p class="text-xs text-gray-600 mt-0.5">Team DreamSTEP of KAIST</p>
        <p class="text-xs text-gray-500 mt-1">
          Role: Safe path planning using TRG-Planner
        </p>
        <a href="https://quadruped-robot-challenges.notion.site/ICRA-2023-Quadruped-Robot-Challenges-0d1513db048e40e1bbe6dd4ba5b78cdc"
          class="text-xs text-blue-700 hover:underline mt-1 inline-block" target="_blank">[Competition Website]</a>
      </div>
    </div>

    <div class="border-t border-gray-100"></div>

    <!-- ICRA 2024 -->
    <div class="flex gap-6 items-start">
      <img src="/images/dreamtrip.png" alt="ICRA 2024 Challenge" class="w-36 h-28 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
        onerror="this.onerror=null;this.style.display='none';" />
      <div>
        <p class="text-sm font-semibold text-gray-900 leading-snug">
          Autonomous Quadrupedal Robot Challenge at ICRA 2024, Yokohama, Japan
        </p>
        <p class="text-sm font-bold text-gray-700 mt-1">🥈 2nd Place</p>
        <p class="text-xs text-gray-600 mt-0.5">Team DreamTRIP of KAIST</p>
        <p class="text-xs text-gray-500 mt-1">
          Role: Safe path planning using TRG-Planner
        </p>
        <a href="https://quadruped-robot-challenges.notion.site/ICRA-2024-Quadruped-Robot-Challenges-d208b535269d4a79b2893a84c1d4b2df"
          class="text-xs text-blue-700 hover:underline mt-1 inline-block" target="_blank">[Competition Website]</a>
      </div>
    </div>

    <div class="border-t border-gray-100"></div>

    <!-- KROC 2024 -->
    <div class="flex gap-6 items-start">
      <img src="/images/kroc_2024.png" alt="KROC 2024" class="w-36 h-28 object-cover rounded border border-gray-200 flex-shrink-0 bg-gray-50"
        onerror="this.onerror=null;this.style.display='none';" />
      <div>
        <p class="text-sm font-semibold text-gray-900 leading-snug">
          KROC 2024 RED Show
        </p>
        <p class="text-sm font-bold text-blue-700 mt-1">🏆 Best Work Award</p>
        <p class="text-xs text-gray-500 mt-1">
          Development of various gait pattern locomotion for quadruped robots using deep reinforcement learning
        </p>
        <a href="https://urobot.kaist.ac.kr/announcement/?uid=517&mod=document&pageid=1"
          class="text-xs text-blue-700 hover:underline mt-1 inline-block" target="_blank">[Announcement]</a>
      </div>
    </div>

  </div>
</Layout>
