---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services" description="Academic services and reviewer activities of Dongkyu Lee">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Academic Services</h1>
  <p class="text-sm text-gray-500 mb-8">Reviewer activities and professional contributions.</p>

  <!-- Reviewer Section -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-800 mb-4 border-b border-gray-200 pb-2">Journal Reviewer</h2>
    <ul class="space-y-2 text-sm text-gray-700">
      <li class="flex items-start gap-2">
        <span class="text-blue-700 mt-0.5">▸</span>
        <span>IEEE Robotics and Automation Letters (RA-L)</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-blue-700 mt-0.5">▸</span>
        <span>IEEE Transactions on Industrial Electronics (TIE)</span>
      </li>
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-800 mb-4 border-b border-gray-200 pb-2">Conference Reviewer</h2>
    <ul class="space-y-2 text-sm text-gray-700">
      <li class="flex items-start gap-2">
        <span class="text-blue-700 mt-0.5">▸</span>
        <span>IEEE International Conference on Robotics and Automation (ICRA)</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-blue-700 mt-0.5">▸</span>
        <span>IEEE/RSJ International Conference on Intelligent Robots and Systems (IROS)</span>
      </li>
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-800 mb-4 border-b border-gray-200 pb-2">Competition Organization &amp; Participation</h2>
    <ul class="space-y-3 text-sm text-gray-700">
      <li class="flex items-start gap-2">
        <span class="text-blue-700 mt-0.5">▸</span>
        <div>
          <span class="font-medium">Autonomous Quadrupedal Robot Challenge @ ICRA 2023</span>
          <span class="text-gray-500"> – Winner (1st Place), London, UK</span>
        </div>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-blue-700 mt-0.5">▸</span>
        <div>
          <span class="font-medium">Autonomous Quadrupedal Robot Challenge @ ICRA 2024</span>
          <span class="text-gray-500"> – 2nd Place, Yokohama, Japan</span>
        </div>
      </li>
    </ul>
  </section>

  <p class="text-xs text-gray-400 mt-6 italic">
    This page will be updated as additional service activities are confirmed.
  </p>
</Layout>
