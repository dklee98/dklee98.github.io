---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Dongkyu Lee - Robotics Researcher, KAIST PhD Candidate, CTO at URobotics Corp." } = Astro.props;

const navItems = [
  { label: "About", href: "#about" },
  { label: "News", href: "#news" },
  { label: "Education", href: "#education" },
  { label: "Publications", href: "#publications" },
  { label: "Experience", href: "#experience" },
  { label: "Awards", href: "#awards" },
  { label: "Services", href: "#services" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <title>{title} | Dongkyu Lee</title>
    <style>
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-white border-b border-gray-200">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="#about" class="text-lg font-semibold text-gray-900 hover:text-blue-700 transition-colors">
          Dongkyu Lee
        </a>
        <ul class="flex items-center gap-6">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm font-medium text-gray-600 transition-colors hover:text-blue-700"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-6 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 mt-16">
      <div class="max-w-4xl mx-auto px-6 py-6 text-center text-sm text-gray-500">
        <p>© {new Date().getFullYear()} Dongkyu Lee. Built with Astro & Tailwind CSS.</p>
      </div>
    </footer>
  </body>
</html>
