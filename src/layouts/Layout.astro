---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Dongkyu Lee - Robotics Researcher, KAIST PhD Candidate, CTO at URobotics Corp." } = Astro.props;

const navItems = [
  { label: "About", href: "#about" },
  { label: "News", href: "#news" },
  { label: "Experience", href: "#experience" },
  { label: "Highlights", href: "#highlights" },
  { label: "Awards", href: "#awards" },
  { label: "Publications", href: "#other-publications" },
  { label: "Services", href: "#services" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico?v=3" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
    <title>{title} | Dongkyu Lee</title>
    <style>
      html { scroll-behavior: smooth; color-scheme: light; }
      html.dark { color-scheme: dark; }
      html.dark a.link { text-decoration-color: rgba(147,197,253,0.6); color: #93c5fd; }
      html.dark a.link:hover { text-decoration-color: rgba(147,197,253,1); color: #bfdbfe; }
      body { font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
      section[id] { scroll-margin-top: 72px; }
      /* Link underline style */
      a.link {
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(15,37,96,0.6);
        transition: text-decoration-color 0.2s;
      }
      a.link:hover {
        text-decoration-color: rgba(15,37,96,1);
      }
      a { text-decoration: none; }
      .hover-underline {
        position: relative;
      }
      .hover-underline::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        width: 0;
        height: 1px;
        background: currentColor;
        transition: width 0.2s ease;
      }
      .hover-underline:hover::after {
        width: 100%;
      }
    </style>
    <script is:inline>
      // Apply theme before paint to avoid flash
      (function() {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 font-sans antialiased">
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="#about" class="text-lg font-semibold text-gray-900 dark:text-gray-100 hover:text-[#0f2560] transition-colors">
          Dongkyu Lee
        </a>
        <!-- Desktop nav links -->
        <ul class="hidden md:flex items-center gap-6">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm font-medium text-gray-600 dark:text-gray-300 transition-colors hover:text-[#0f2560] dark:hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <!-- Right side buttons -->
        <div class="flex items-center gap-1">
          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            class="flex items-center justify-center w-9 h-9 rounded text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            aria-label="Toggle dark mode"
          >
            <span id="theme-icon">🌙</span>
          </button>
          <!-- Hamburger button (mobile only) -->
          <button
            id="menu-toggle"
            class="md:hidden flex items-center justify-center w-9 h-9 rounded text-gray-600 dark:text-gray-300 hover:text-[#0f2560] hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <span id="hamburger-icon" class="text-xl leading-none select-none">☰</span>
          </button>
        </div>
      </nav>
    </header>

    <!-- Mobile side drawer overlay -->
    <div id="menu-overlay" class="fixed inset-0 z-40 hidden md:hidden" style="background: rgba(0,0,0,0.3);"></div>

    <!-- Mobile side drawer -->
    <div
      id="mobile-menu"
      class="fixed top-0 right-0 h-full w-56 bg-white dark:bg-gray-900 shadow-xl z-50 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden border-l border-gray-100 dark:border-gray-700"
    >
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 dark:border-gray-700">
        <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Menu</span>
        <button id="menu-close" class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white text-xl leading-none">✕</button>
      </div>
      <ul class="px-4 py-4 flex flex-col gap-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="mobile-nav-link block py-2.5 px-3 text-sm font-medium text-gray-600 dark:text-gray-300 rounded hover:text-[#0f2560] dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-6 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-gray-700 mt-16">
      <div class="max-w-4xl mx-auto px-6 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Dongkyu Lee</p>
          <p class="text-xs text-gray-400 dark:text-gray-500">Built with Astro & Tailwind CSS · © {new Date().getFullYear()}</p>
          <div class="flex gap-4 text-xs text-gray-500 dark:text-gray-400">
            <a href="#about" class="hover:text-gray-800 dark:hover:text-gray-200 transition-colors">Back to top ↑</a>
          </div>
        </div>
      </div>
    </footer>
  <script>
    // Smooth scroll for all anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href === '#') return;
        const target = document.querySelector(href);
        if (!target) return;
        e.preventDefault();
        const navHeight = document.querySelector('header')?.offsetHeight ?? 72;
        const top = target.getBoundingClientRect().top + window.scrollY - navHeight - 8;
        window.scrollTo({ top, behavior: 'smooth' });
      });
    });

    // Mobile side drawer
    const menuToggle = document.getElementById('menu-toggle');
    const menuClose = document.getElementById('menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('menu-overlay');

    function openMenu() {
      mobileMenu?.classList.remove('translate-x-full');
      overlay?.classList.remove('hidden');
      menuToggle?.setAttribute('aria-expanded', 'true');
    }

    function closeMenu() {
      mobileMenu?.classList.add('translate-x-full');
      overlay?.classList.add('hidden');
      menuToggle?.setAttribute('aria-expanded', 'false');
    }

    menuToggle?.addEventListener('click', () => {
      const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    menuClose?.addEventListener('click', closeMenu);
    overlay?.addEventListener('click', closeMenu);

    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => closeMenu());
    });

    // Dark mode toggle
    const themeToggle = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const html = document.documentElement;

    function applyTheme(dark: boolean) {
      if (dark) {
        html.classList.add('dark');
        if (themeIcon) themeIcon.textContent = '☀️';
      } else {
        html.classList.remove('dark');
        if (themeIcon) themeIcon.textContent = '🌙';
      }
    }

    // Sync icon with current theme (already applied by inline script)
    applyTheme(html.classList.contains('dark'));

    themeToggle?.addEventListener('click', () => {
      const isDark = html.classList.contains('dark');
      applyTheme(!isDark);
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    });
  </script>
  </body>
</html>
